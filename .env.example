# Shift Handover Log - Environment Configuration
# Copy this file to .env and adjust values as needed.
# For local development, defaults work without any configuration.

# Server port (default: 8500)
PORT=8500

# JWT secret for authentication (change in production!)
JWT_SECRET=a-strong-secret-key-change-in-production

# Frontend URL (for production CORS - optional)
# FRONTEND_URL=http://localhost:8500

# SMTP - Optional, for sending password emails to users
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
